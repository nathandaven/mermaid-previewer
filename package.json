{
  "name": "mermaid-previewer-fork",
  "displayName": "Mermaid Previewer (Fork)",
  "version": "1.6.0",
  "description": "Preview and export mermaid.",
  "type": "module",
  "scripts": {
    "dev": "plasmo dev --verbose",
    "test": "playwright test",
    "test-ui": "playwright test --ui",
    "test-report": "playwright show-report",
    "build": "pnpm run build:chrome && pnpm run build:firefox && pnpm run build:safari",
    "build:chrome": "plasmo build --verbose --hoist --target=chrome-mv3 --zip",
    "build:firefox": "plasmo build --verbose --hoist --target=firefox-mv3 --zip",
    "build:safari": "plasmo build --verbose --hoist --target=safari-mv3 --zip",
    "package": "plasmo package",
    "gcp-token": "pnpm dlx gcp-refresh-token",
    "dep-outdate": "pnpm outdated",
    "format": "pnpm exec prettier '**/*.{js,ts,jsx,tsx,cjs,cts,mjs,mts,vue,astro}' --write --ignore-unknown",
    "web-ext": "source .env && cd build/firefox-mv3-prod && web-ext sign --channel=unlisted --api-key=${AMO_JWT_ISSUER} --api-secret=${AMO_JWT_SECRET}",
    "web-ext:listed": "source .env && web-ext sign --channel=listed --api-key=${AMO_JWT_ISSUER} --api-secret=${AMO_JWT_SECRET}  --amo-metadata=./amo-metadata.json --source-dir ./build/firefox-mv3-prod"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nathandaven/mermaid-previewer.git"
  },
  "keywords": [
    "chrome-extension",
    "mermaid"
  ],
  "author": "nathandaven",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nathandaven/mermaid-perviewer/issues"
  },
  "homepage": "https://github.com/nathandaven/mermaid-perviewer#readme",
  "dependencies": {
    "@floating-ui/dom": "1.6.13",
    "@fluentui/react-components": "9.60.0",
    "@fluentui/react-icons": "2.0.279",
    "@plasmohq/messaging": "0.7.1",
    "@plasmohq/storage": "1.15.0",
    "mermaid": "11.4.1",
    "plasmo": "0.90.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "web-ext": "^10.0.0",
    "webextension-polyfill": "0.12.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.4.1",
    "@playwright/test": "1.50.1",
    "@types/chrome": "0.0.308",
    "@types/node": "22.13.9",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/webextension-polyfill": "0.12.3",
    "autoprefixer": "10.4.20",
    "dotenv": "16.4.7",
    "postcss": "8.5.3",
    "prettier": "3.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.2"
  },
  "manifest": {
    "browser_specific_settings": {
      "gecko": {
        "id": "mermaid-previewer@nathandaven.com"
      },
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "host_permissions": [
      "https://*/*",
      "file:///"
    ],
    "permissions": [
      "downloads",
      "activeTab",
      "scripting"
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "mermaid/dist/mermaid.min.js"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lmdb",
      "sharp",
      "vue-demi"
    ]
  }
}
